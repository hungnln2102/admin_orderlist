# Sao chép thành backend/.env.local (gitignored) — chỉ dùng khi chạy local (NODE_ENV không phải production, APP_ENV không phải production/docker).
#   copy env.local.example .env.local
#
# File này ghi đè `.env` sau khi loadEnv chạy. Không dùng cho container production.

# --- Database local (trùng Beekeeper / stack bạn chạy) ---
# Ưu tiên một trong: DATABASE_URL | POSTGRES_URL | PG_URL. Nếu không set, app ghép từ DB_* bên dưới.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/my-store
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=my-store
# Website/docker-compose.postgres.local.yml mặc định: DB_PASS=password. Docker admin_orderlist: DB_NAME=mydtbmav thường gặp hơn my-store.
#
# DB mới / trống: `npm run migrate:latest` (cần file SQL trong `database/migrations/`; đồng bộ legacy: `npm run db:sync-legacy-sql`).
# Nếu `admin.users` chưa có dòng: `set DEV_ADMIN_PASSWORD=MatKhauMạnh&& npm run db:seed-dev-admin` (user mặc định mavryk). Kiểm tra: `npm run db:probe`.

# --- Schema finance / tổng hợp tháng ---
# Webhook + API Tổng quan ghi/đọc `{SCHEMA_FINANCE}.dashboard_monthly_summary` (mặc định: dashboard).
# Nếu DB chỉ có finance.dashboard_monthly_summary (legacy), đặt: DB_SCHEMA_FINANCE=finance
# Kiểm tra: SELECT table_schema FROM information_schema.tables WHERE table_name = 'dashboard_monthly_summary';

# --- Redis (tùy chọn; không set → session in-memory) ---
# REDIS_URL=redis://127.0.0.1:6379

# --- Dev CORS / admin Vite ---
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SESSION_SECRET=dev-only-secret

# Port API local
# PORT=3001
