# Sao chép thành backend/.env.local (gitignored) — chỉ dùng khi chạy local (NODE_ENV không phải production, APP_ENV không phải production/docker).
#   copy env.local.example .env.local
#
# File này ghi đè `.env` sau khi loadEnv chạy. Không dùng cho container production.

# --- Database local ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/my-store

# --- Schema finance / tổng hợp tháng ---
# Webhook + API Tổng quan ghi/đọc `{SCHEMA_FINANCE}.dashboard_monthly_summary` (mặc định: dashboard).
# Nếu DB chỉ có finance.dashboard_monthly_summary (legacy), đặt: DB_SCHEMA_FINANCE=finance
# Kiểm tra: SELECT table_schema FROM information_schema.tables WHERE table_name = 'dashboard_monthly_summary';

# --- Redis (tùy chọn; không set → session in-memory) ---
# REDIS_URL=redis://127.0.0.1:6379

# --- Dev CORS / admin Vite ---
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SESSION_SECRET=dev-only-secret

# Port API local
# PORT=3001
