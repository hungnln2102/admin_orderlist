# Sao chép thành backend/.env.docker (gitignored) — dùng cho production / docker-compose.
#   copy env.docker.example .env.docker
#
# docker-compose.yml đã đặt APP_ENV=docker và NODE_ENV=production; file này chứa secret & URL nội bộ.

# --- Bắt buộc ---
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@postgres:5432/mydtbmav

# Redis (service tên `redis` trong compose)
REDIS_URL=redis://redis:6379
# Production hardening: không cho fallback session in-memory.
# Nếu tắt Redis hoặc thiếu config, backend sẽ fail-fast khi boot.
REDIS_ENABLED=true

# Session / bảo mật (tự sinh chuỗi dài)
SESSION_SECRET=change-me-long-random

# --- API / webhook ---
PORT=3001
SEPAY_PORT=5000
SEPAY_HOST=0.0.0.0

# CORS — domain admin + website production (phẩy)
FRONTEND_ORIGINS=https://admin.mavrykpremium.store,https://www.mavrykpremium.store,https://mavrykpremium.store

# Sepay (điền giá trị thật)
# SEPAY_WEBHOOK_SECRET=
# SEPAY_API_KEY=

# Telegram / thông báo (tùy chọn)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Dùng duy nhất 1 chat id cho mọi luồng. Phân loại bằng topic id.
# TELEGRAM_ORDER_TOPIC_ID=
# TELEGRAM_IMPORT_ORDER_TOPIC_ID=
# TELEGRAM_FINANCE_TOPIC_ID=

# Renew Adobe API — nếu chạy service riêng
# RENEW_ADOBE_API_BASE_URL=http://renew-adobe-api:xxxx
