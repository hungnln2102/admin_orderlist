# Sao chép thành backend/.env.local (cùng thư mục với .env) để ghi đè khi chạy local.
#   copy env.postgres.local.example .env.local
#
# Bật trước: Postgres từ Website (xem ../Website/docker-compose.postgres.local.yml) hoặc
# mọi Postgres local có cùng dump/schema với ứng dụng này.

# Bắt buộc khi dùng DB local (mặc định: cùng my-store với my-store/Website)
DATABASE_URL=postgresql://postgres:password@localhost:5432/my-store

# Tùy chọn: session Redis (không cần nếu chấp nhận in-memory khi dev)
# Sau: docker compose -f ../docker-compose.local-dev.yml up -d
# REDIS_URL=redis://127.0.0.1:6379
