# PostgreSQL connection string
# - For the bundled docker-compose Postgres service, use:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mydtbmav
# - If you use the host Postgres, point to host.docker.internal or your host IP.
DATABASE_URL=postgresql://USER:PASSWORD@host.docker.internal:5432/DB_NAME

# API server
PORT=3001
FRONTEND_ORIGINS=http://admin.mavrykpremium.store,https://admin.mavrykpremium.store,https://mavrykpremium.store,https://www.mavrykpremium.store
# Base URL used to build absolute image links (recommended when behind HTTPS proxy)
PUBLIC_BASE_URL=https://admin.mavrykpremium.store

# Dashboard: ô "Thuế của tháng" = doanh thu tháng × (giá trị này / 100). Ví dụ 10 = VAT 10%. 0 = hiển thị 0 ₫.
# DASHBOARD_MONTHLY_TAX_RATE_PERCENT=0

# Scheduler (optional overrides)
APP_TIMEZONE=Asia/Ho_Chi_Minh
CRON_SCHEDULE=1 0 * * *
RUN_CRON_ON_START=false
# MOCK_DATE=2025-01-01

# Redis (dev + production)
# - Development:
#   REDIS_ENABLED=false (không dùng Redis) hoặc chạy local Redis rồi bật true.
# - Production:
#   REDIS_ENABLED=true và nên dùng REDIS_URL của managed Redis (có auth/TLS).
REDIS_ENABLED=false
# Option A (recommended): URL
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=rediss://:PASSWORD@your-redis-host:6380/0
# Option B: host/port/password/db
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=false
# Optional tuning
# REDIS_CONNECT_TIMEOUT_MS=5000
# REDIS_MAX_RETRIES=2
# REDIS_ERROR_LOG_INTERVAL_MS=30000

# Backup DB lên Google Drive (scheduler). Cần pg_dump trong PATH hoặc PG_DUMP_PATH.
# Linux/VPS: apt install postgresql-client — thường /usr/bin/pg_dump (Docker backend image đã có).
# ENABLE_DB_BACKUP=false
# BACKUP_DATABASE_URL=postgresql://...
# PG_DUMP_PATH=/usr/bin/pg_dump
# Windows (dev): PG_DUMP_PATH=C:\\Program Files\\PostgreSQL\\16\\bin\\pg_dump.exe
# BACKUP_RETENTION_DAYS=7
# BACKUP_LOG_FILE=./logs/backup.log

# Giá MAVS (sinh viên) = nội suy giữa MAVC và MAVL khi variant.pct_stu NULL.
# Giá trị 0–1 (ví dụ 0.35 = 35% từ MAVC lên MAVL). Mặc định code: 0.35.
# DEFAULT_PCT_STU=0.35

# Telegram (orders, cron, backend warnings)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Forum topic id for new-order messages. Omit to send without topic (wrong id causes "message thread not found").
# TELEGRAM_ORDER_TOPIC_ID=
# SEND_ORDER_TO_TOPIC=true
# SEND_ORDER_NOTIFICATION=true
# ERROR_TOPIC_ID=6
# SEND_ERROR_NOTIFICATION=true
# ZERO_DAYS_TOPIC_ID=2563
# FOUR_DAYS_TOPIC_ID=12
# MAVN: no QR; sample topic link https://t.me/c/2934465528/4187
# TELEGRAM_IMPORT_ORDER_CHAT_ID=-1002934465528
# TELEGRAM_IMPORT_ORDER_TOPIC_ID=4187
