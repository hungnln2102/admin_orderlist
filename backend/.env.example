# PostgreSQL connection string
# - For the bundled docker-compose Postgres service, use:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mydtbmav
# - If you use the host Postgres, point to host.docker.internal or your host IP.
DATABASE_URL=postgresql://USER:PASSWORD@host.docker.internal:5432/DB_NAME

# API server
PORT=3001
FRONTEND_ORIGINS=http://admin.mavrykpremium.store,https://admin.mavrykpremium.store
# Base URL used to build absolute image links (recommended when behind HTTPS proxy)
PUBLIC_BASE_URL=https://admin.mavrykpremium.store

# Scheduler (optional overrides)
APP_TIMEZONE=Asia/Ho_Chi_Minh
CRON_SCHEDULE=1 0 * * *
RUN_CRON_ON_START=false
# MOCK_DATE=2025-01-01

# Renew Adobe — hàng đợi check/delete (tránh 10–100 browser cùng lúc)
# Chạy ngầm (headless) có thể tăng CONCURRENT; mỗi Chrome ~300MB RAM.
# ADOBE_CHECK_MAX_CONCURRENT=2
# ADOBE_CHECK_MAX_QUEUE=50

# Puppeteer: mở browser để xem khi test (chạy backend trên máy có màn hình).
# =false → mở cửa sổ Chrome; =true hoặc bỏ qua → chạy ngầm (dùng trên server/Docker không có display).
# PUPPETEER_HEADLESS=false
# Đường dẫn Chrome (tùy chọn): dùng Chrome cài sẵn thay Chromium của Puppeteer.
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
